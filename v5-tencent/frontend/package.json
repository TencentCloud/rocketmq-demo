    "format": "prettier --write \"src/**/*.{js,ts,vue,json,css,scss}\""
  },
  "dependencies": {
    "axios": "^1.13.4",
    "dayjs": "^1.11.19",
    "pinia": "^3.0.4",
    "tdesign-vue-next": "^1.18.0",
    "vue": "^3.5.24",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.9",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.7.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.4"
